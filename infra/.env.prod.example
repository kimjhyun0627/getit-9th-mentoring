# Production environment template. Copy to `infra/.env.prod` on the VM, then
# fill in real values. Never commit the populated file.

# ---- Traefik / ACME ----
# Email used for Let's Encrypt account + expiry notices.
ACME_EMAIL=admin@get-it.cloud

# ---- Image registry ----
# GitHub Container Registry — workflow pushes ghcr.io/<owner>/<image>:<tag>
IMAGE_REGISTRY=ghcr.io/kimjhyun0627
IMAGE_TAG=latest

# ---- MySQL ----
# Shared root credential (admin only — not used by app services).
MYSQL_ROOT_PASSWORD=change-me-strong-root-password
# Single app user across the 5 service DBs. Service-isolated users are a Phase 5
# hardening item — for the bootcamp 단일 VM 운영에선 운영 부담이 더 큼.
MYSQL_APP_PASSWORD=change-me-app-password
MYSQL_APP_USER=getit

# ---- JWT (shared across 5 APIs) ----
# REQUIRED. Generate a real secret with:
#   openssl rand -base64 48
# 5 BE (auth/hobby/shelf/board/letter) 가 같은 secret 으로 토큰을 서명/검증하므로
# 운영 배포 전 반드시 실제 값으로 교체. example placeholder 그대로 두면 모든 BE 가
# @getit/env-validator 에서 boot 단계 throw → 컨테이너 즉시 종료 (Issue #575).
JWT_SECRET=__REPLACE_WITH_openssl_rand_base64_48__
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---- Cookies (SSO across *.get-it.cloud) ----
COOKIE_DOMAIN=.get-it.cloud
COOKIE_SECURE=true

# ---- External APIs ----
# hobby-api 가 카카오 로그인 (인증) 용 으로 사용 — Kakao 개발자 콘솔의 REST API 키.
KAKAO_API_KEY=
# shelf-api 가 카카오 도서 검색 API 용 으로 사용 — 별도 앱/키 권장.
# 미설정/공백/placeholder 시 NODE_ENV=production 의 shelf-api 가 boot 단계에서 throw.
KAKAO_BOOK_API_KEY=

# ---- School auth guard (hobby-api) ----
# 학교 인증 안 한 사용자의 hobby 모집/신청 mutation 차단 — PRD `.claude/projects/hobby.md`
# / `school-auth.md` 정책. prod 에서는 반드시 `true` 여야 함.
# `true` 가 아니거나 미정의면 NODE_ENV=production 의 hobby-api 가 boot 단계에서 throw.
SCHOOL_AUTH_GUARD_ENABLED=true

# ---- SMTP (auth-api 가 비번 재설정 / 학교 인증 메일 발송) ----
# REQUIRED in production. SMTP_HOST 가 비어있으면 auth-api 는 boot 단계에서 throw —
# 메일이 안 나가는데 UI 만 "보냈어요" 응답하는 사일런트 실패를 차단 (Issue #575).
# 의도적으로 메일 채널을 끄려면 MAILER_DISABLED_ALLOWED=true 를 설정 (warn 으로 격하).
SMTP_HOST=__REPLACE_WITH_smtp_host__
SMTP_PORT=587
SMTP_USER=__REPLACE_WITH_smtp_user__
SMTP_PASS=__REPLACE_WITH_smtp_password__
SMTP_FROM=GETIT/9 <noreply@get-it.cloud>
# SMTP 채널을 의도적으로 끄려면 "true". 기본은 미설정 (=false) — 운영 부팅 차단.
MAILER_DISABLED_ALLOWED=

# ---- Sentry (optional) ----
SENTRY_DSN=
