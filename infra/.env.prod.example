# Production environment template. Copy to `infra/.env.prod` on the VM, then
# fill in real values. Never commit the populated file.

# ---- Traefik / ACME ----
# Email used for Let's Encrypt account + expiry notices.
ACME_EMAIL=admin@get-it.cloud

# ---- Image registry ----
# GitHub Container Registry — workflow pushes ghcr.io/<owner>/<image>:<tag>
IMAGE_REGISTRY=ghcr.io/kimjhyun0627
IMAGE_TAG=latest

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=change-me-strong-root-password
# Separate app user — all 5 services share this credential (each has its own DB).
MYSQL_APP_USER=getit
MYSQL_APP_PASSWORD=change-me-app-password

# ---- JWT (shared across 5 APIs) ----
JWT_SECRET=change-me-min-32-chars-long-aaaaaaaaaaaaa
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---- Cookies (SSO across *.get-it.cloud) ----
COOKIE_DOMAIN=.get-it.cloud
COOKIE_SECURE=true

# ---- External APIs ----
KAKAO_API_KEY=

# ---- Sentry (optional) ----
SENTRY_DSN=
