# hobby-api 환경 변수 예시. 실제 값으로 채워서 `.env` 로 복사해 사용.
# JS only — dotenv 가 자동 로드.

# ---- Database ----
# 로컬 dev: docker-compose.dev.yml의 mysql 컨테이너 (host=localhost, port=3306)
# prod:    GCP VM 내부 docker network의 mysql 서비스
DATABASE_URL="mysql://user:pass@localhost:3306/hobby_dev"

# ---- Server ----
PORT="3002"
NODE_ENV="development"

# ---- SSO ----
# auth-api 와 동일한 JWT_SECRET 사용 (통합 SSO 검증용).
JWT_SECRET="change-me-min-32-chars-long-aaaaaaaaaaaaa"
COOKIE_DOMAIN=".get-it.cloud"

# ---- CORS ----
CORS_ORIGINS="http://localhost:5173,https://hobby.get-it.cloud"
