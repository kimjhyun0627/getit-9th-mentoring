# board-api 환경 변수 예시. `.env` 로 복사해 사용.
# JS only — dotenv 가 자동 로드.

# ---- Database ----
# 로컬 dev: docker-compose.dev.yml의 mysql 컨테이너 (host=localhost, port=3306)
# prod:    GCP VM 내부 docker network의 mysql 서비스
# auth-api 와 같은 인스턴스를 써도 되고 (DB만 분리), 완전히 분리 인스턴스도 OK.
DATABASE_URL="mysql://user:pass@localhost:3306/board_dev"

# ---- Seed ----
# auth-api seed가 생성한 alice/bob의 id를 주입해야 board seed가 정상 동작.
# 예) pnpm --filter @getit/auth-api prisma:studio 로 확인 후 복붙.
# SEED_OWNER_ID="<alice cuid>"
# SEED_MEMBER_ID="<bob cuid>"

# ---- Server (#46/#47/#48에서 사용) ----
PORT="3003"
NODE_ENV="development"

# ---- JWT (auth-api 와 동일 SECRET 공유 — SSO 검증용) ----
# 32 chars 이상 랜덤값 필수. 생성 예: `openssl rand -hex 32`
JWT_SECRET="replace-this-with-a-secure-random-string-of-at-least-32-characters"

# ---- CORS ----
CORS_ORIGINS="http://localhost:5173,https://board.get-it.cloud"
