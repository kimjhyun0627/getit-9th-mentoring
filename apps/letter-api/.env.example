# letter-api 환경 변수 예시. 실제 값으로 채워서 `.env` 로 복사해 사용.
# JS only — dotenv 가 자동 로드.

# ---- Database ----
# 로컬 dev: docker-compose.dev.yml의 mysql 컨테이너 (host=localhost, port=3306)
# prod:    GCP VM 내부 docker network의 mysql 서비스
DATABASE_URL="mysql://user:pass@localhost:3306/letter_dev"

# ---- Server ----
PORT="3005"
NODE_ENV="development"
# Express `trust proxy` 값. 기본 1 (Traefik 단일 계층).
# TRUST_PROXY="2"

# ---- JWT (auth-api 와 동일 시크릿 — SSO 검증) ----
JWT_SECRET="change-me-min-32-chars-long-aaaaaaaaaaaaa"

# ---- CORS ----
# 콤마 분리 origin. 비면 fail-closed.
CORS_ORIGINS="http://localhost:5173,https://get-it.cloud,https://letter.get-it.cloud"

# ---- Rate limit ----
# POST/PATCH/DELETE burst 차단. 기본 30 / 60s.
RATE_LIMIT_MAX="30"
RATE_LIMIT_WINDOW_MS="60000"
