{
  "name": "@getit/shelf-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "shelf.get-it.cloud/api - 스마트 서재 BE (외부 도서 API 중계 + Book/BookShelf DB)",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "build": "echo \"JS only, skip build\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint --no-error-on-unmatched-pattern src tests prisma",
    "typecheck": "echo \"JS only, skip\"",
    "clean": "rimraf dist .turbo",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@getit/auth-utils": "workspace:*",
    "@getit/env-validator": "workspace:*",
    "@getit/schemas": "workspace:*",
    "@prisma/client": "6.19.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prisma": "6.19.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@getit/config-eslint": "workspace:*",
    "eslint": "^9.18.0",
    "jsonwebtoken": "^9.0.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "undici": "^7.16.0",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "@sentry/node": "^8.0.0"
  }
}
