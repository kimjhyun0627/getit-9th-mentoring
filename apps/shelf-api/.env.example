# shelf-api 환경 변수 예시. 실제 값으로 채워서 `.env` 로 복사해 사용.
# JS only — dotenv 가 자동 로드.

# ---- Database ----
# 로컬 dev: docker-compose.dev.yml의 mysql 컨테이너 (host=localhost, port=3306)
# prod:    GCP VM 내부 docker network의 mysql 서비스
DATABASE_URL="mysql://user:pass@localhost:3306/shelf_dev"

# ---- Server ----
PORT="3003"
NODE_ENV="development"

# Express trust proxy 계층 수 (Traefik 단일 = 1).
# Cloudflare 거치면 2, 직접 노출이면 0.
TRUST_PROXY="1"

# 콤마 분리 origin 화이트리스트. 비우면 CORS 자체 거부 (fail-closed).
# 예: "https://shelf.get-it.cloud,http://localhost:5173"
CORS_ORIGINS=""

# ---- 외부 도서 API (BE 전용 — 절대 FE 노출 X) ----
# 카카오 도서 API 키. https://developers.kakao.com 에서 REST API 키 발급.
# 응답 형식 / 쿼리: https://developers.kakao.com/docs/latest/ko/daum-search/dev-guide#search-book
KAKAO_BOOK_API_KEY=""

# ---- Book 캐시 TTL ----
# 외부 API 응답 캐시 만료(시간 단위). 기본 24h.
BOOK_CACHE_TTL_HOURS="24"

# ---- 옵션 ----
# Sentry DSN. 비우면 비활성화.
SENTRY_DSN=""
