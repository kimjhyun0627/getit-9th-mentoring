# shelf-api 환경 변수 예시. 실제 값으로 채워서 `.env` 로 복사해 사용.
# JS only — dotenv 가 자동 로드.

# ---- Database ----
# 로컬 dev: docker-compose.dev.yml의 mysql 컨테이너 (host=localhost, port=3306)
# prod:    GCP VM 내부 docker network의 mysql 서비스
DATABASE_URL="mysql://user:pass@localhost:3306/shelf_dev"

# ---- Server ----
PORT="3003"
NODE_ENV="development"

# ---- 외부 도서 API (BE 전용 — 절대 FE 노출 X) ----
# 카카오 도서 API 키 (예시). 알라딘/네이버로 교체 가능.
# KAKAO_BOOK_API_KEY=""
# ALADIN_TTB_KEY=""
# NAVER_BOOK_CLIENT_ID=""
# NAVER_BOOK_CLIENT_SECRET=""

# ---- Book 캐시 TTL ----
# 외부 API 응답 캐시 만료(시간 단위). 기본 24h.
BOOK_CACHE_TTL_HOURS="24"
