# auth-api 환경 변수 예시. 실제 값으로 채워서 `.env` 로 복사해 사용.
# JS only — dotenv 가 자동 로드.

# ---- Database ----
# 로컬 dev: docker-compose.dev.yml의 mysql 컨테이너 (host=localhost, port=3306)
# prod:    GCP VM 내부 docker network의 mysql 서비스
DATABASE_URL="mysql://user:pass@localhost:3306/auth_dev"

# ---- JWT ----
# 32자 이상 권장. prod는 GitHub Secrets / .env(서버) 에서 주입.
JWT_SECRET="change-me-min-32-chars-long-aaaaaaaaaaaaa"
# Access token TTL — 짧게 (보안). 만료되면 refresh 토큰으로 회전.
JWT_ACCESS_EXPIRES_IN="15m"
# Refresh token TTL (DB RefreshToken.expiresAt 계산용). 회전 가능.
JWT_REFRESH_EXPIRES_IN="30d"

# ---- Cookie (통합 SSO) ----
# 모든 *.get-it.cloud 서브도메인이 같은 쿠키를 공유.
COOKIE_DOMAIN=".get-it.cloud"
# dev: false (http://localhost), prod: true (HTTPS only)
COOKIE_SECURE="false"
# HttpOnly + SameSite=Lax 는 코드 레벨 고정.

# ---- Server ----
PORT="3001"
NODE_ENV="development"
# Express `trust proxy` 값. 기본 1 (Traefik 단일 계층).
# 다중 프록시(예: Cloudflare → LB → Ingress)일 땐 그만큼의 정수로 올려라.
# TRUST_PROXY="2"

# ---- CORS ----
# 콤마 분리 origin 목록. *.get-it.cloud 의 모든 FE 서브도메인 허용.
# 비워두면 fail-closed (cross-origin 전면 거부 + credentials off).
CORS_ORIGINS="http://localhost:5173,https://get-it.cloud,https://auth.get-it.cloud,https://hobby.get-it.cloud,https://shelf.get-it.cloud,https://board.get-it.cloud,https://letter.get-it.cloud"

# ---- 보안 ----
# bcrypt cost (회원가입 시 password 해싱). 12 권장.
BCRYPT_COST="12"

# ---- Sentry (옵션) ----
# SENTRY_DSN=""
