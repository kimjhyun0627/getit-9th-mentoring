// auth-api Prisma schema
// 5 BE 앱이 공유하는 통합 SSO Users 테이블 + Refresh Token 회전 테이블.
// JwtPayload.sub === User.id (cuid 문자열) — @getit/schemas/auth 와 호환.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 통합 SSO 사용자.
/// - id: cuid 문자열 (다른 5개 BE 앱이 user_id FK로 참조)
/// - email: 로그인 식별자, unique
/// - passwordHash: bcrypt cost 12 해시 (raw password 절대 저장 X)
/// - name: 표시 이름 (40자 이내, @getit/schemas/auth SignupInput 과 일치)
/// - emailVerifiedAt: 이메일 인증 완료 시각 (null = 미인증). Phase 6c (#226).
/// - deletedAt: 회원 탈퇴(soft-delete) 시각. null = 활성. 탈퇴 시 email 은
///   `deleted+<id>@deleted.local` 로 치환해 unique 충돌 회피 (#231).
model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  name                String
  emailVerifiedAt     DateTime?
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  emailVerifyTokens   EmailVerifyToken[]
}

/// Refresh token 회전용 저장소.
/// - tokenHash: 평문 토큰의 SHA-256 해시 (DB 유출 시 토큰 재사용 방지)
/// - expiresAt: 토큰 만료 시각 (보통 30일)
/// - revokedAt: 로그아웃/회전 시 마킹 (null이면 유효)
/// - onDelete: Cascade — 유저 삭제 시 토큰 자동 정리
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// 비밀번호 재설정 1회용 토큰 (Issue #221).
/// - tokenHash: 평문 토큰의 SHA-256 해시. 평문은 절대 저장 X.
/// - expiresAt: 발급 시점 + 15분 (RESET_TOKEN_TTL_MIN).
/// - usedAt: 사용된 시점 (null이면 미사용). 사용 후엔 재사용 불가.
/// - 보안: 토큰 발급/사용 모두 enumeration 방어를 위해 응답은 항상 200.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// 이메일 인증 1회용 토큰 (Issue #226).
/// - signup 직후 발급, 24h TTL.
/// - 사용 시 User.emailVerifiedAt 채워주고 토큰은 usedAt 마킹.
/// - 평문은 절대 저장 X — SHA-256 해시만.
model EmailVerifyToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
